{
  "manifest_version": 3,
  "name": "Pluks — Select to Copy",
  "short_name": "Pluks",
  "version": "0.1.0",
  "description": "Select any text and it's instantly copied — no Ctrl+C needed. Searchable 100-item history. Free, local. Anonymous usage stats help us improve — opt out in the popup.",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Pluks — click to see history"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["config.js", "analytics.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://us.i.posthog.com/*",
    "https://*.ingest.sentry.io/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://us.i.posthog.com https://*.ingest.sentry.io"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pluks@pluks.app",
      "strict_min_version": "109.0"
    }
  }
}
